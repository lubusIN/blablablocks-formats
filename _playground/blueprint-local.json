{
    "$schema": "https://playground.wordpress.net/blueprint-schema.json",
    "landingPage": "/wp-admin/post.php?post=11&action=edit",
    "preferredVersions": {
        "php": "8.2",
        "wp": "6.7"
    },
    "login": true,
    "features": {
        "networking": true
    },
    "steps": [
        {
            "step": "updateUserMeta",
            "meta": {
                "admin_color": "modern",
                "show_welcome_panel": 0
            },
            "userId": 1
        },
        {
            "step": "setSiteOptions",
            "options": {
                "blogname": "BlaBlaBlocks Formats | Local Dev 🧑‍💻"
            }
        },
        {
            "step": "importWxr",
            "file": {
                "resource": "bundled",
                "path": "/demo-content.xml"
            }
        }
    ]
}